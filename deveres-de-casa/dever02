import time

def fatorial(n):
    # quando n é 0 ou 1
    if n == 0 or n == 1:
        return 1
    
    # Caso recursivo
    return n * fatorial(n - 1)


# Valores de entrada:
valores = [10, 100, 500, 1000]

for n in valores:
    
    inicio = time.time() 
    
    resultado = fatorial(n)  
    
    fim = time.time() 
    
    tempo_execucao = fim - inicio  
    
    print("n =", n)
    print("Tempo de execução:", tempo_execucao, "segundos")
    print("--------------------------")
